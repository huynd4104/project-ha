rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function isAdmin() {
      return signedIn()
        && exists(userDoc())
        && get(userDoc()).data.role == "ADMIN"
        && get(userDoc()).data.isActive == true;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function writesOwnUserData() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function safeChildProfileKeys() {
      return request.resource.data.keys().hasOnly([
        "userId",
        "displayName",
        "name",
        "age",
        "gender",
        "note",
        "primaryDifficulty",
        "secondaryDifficulties",
        "learningGoals",
        "supportLevel",
        "dailyDurationMinutes",
        "coLearningMode",
        "interests",
        "accessibilityPreferences",
        "currentPathId",
        "currentProgramId",
        "selectedAt",
        "createdAt",
        "updatedAt"
      ]);
    }

    function safeOwnerChildUpdate() {
      return request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "displayName",
          "name",
          "age",
          "gender",
          "note",
          "primaryDifficulty",
          "secondaryDifficulties",
          "learningGoals",
          "supportLevel",
          "dailyDurationMinutes",
          "coLearningMode",
          "interests",
          "accessibilityPreferences",
          "currentPathId",
          "currentProgramId",
          "selectedAt",
          "updatedAt"
        ]);
    }

    function isPublished() {
      return resource.data.status == "PUBLISHED";
    }

    function safeUserCreate() {
      return request.resource.data.keys().hasOnly([
          "uid",
          "email",
          "fullName",
          "displayName",
          "avatarUrl",
          "role",
          "isActive",
          "emailVerified",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == "PARENT"
        && request.resource.data.isActive == true
        && request.resource.data.emailVerified == false;
    }

    function safeOwnerUserUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "fullName",
        "displayName",
        "avatarUrl",
        "updatedAt"
      ]);
    }

    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId && safeUserCreate();
      allow read: if isAdmin() || isOwner(userId);
      allow update: if isAdmin() || (isOwner(userId) && safeOwnerUserUpdate());
      allow delete: if isAdmin();
    }

    match /otps/{userId} {
      allow read, write: if isAdmin();
    }

    match /children/{childId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow create: if writesOwnUserData() && safeChildProfileKeys();
      allow update: if isAdmin()
        || (isOwner(resource.data.userId)
          && safeOwnerChildUpdate());
      allow delete: if isAdmin() || isOwner(resource.data.userId);
    }

    match /npcs/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /mediaAssets/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /qrCodes/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /activationCodes/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /developmentCategories/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /learningGoals/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /skills/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /programs/{id} {
      allow read: if isAdmin() || (signedIn() && isPublished());
      allow write: if isAdmin();
    }

    match /learningPaths/{id} {
      allow read: if isAdmin() || (signedIn() && isPublished());
      allow write: if isAdmin();
    }

    match /pathItems/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /lessons/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /mathQuestions/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /dialogues/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /flashcards/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /activities/{id} {
      allow read: if isAdmin()
        || (signedIn()
          && resource.data.isActive == true
          && get(/databases/$(database)/documents/lessons/$(resource.data.lessonId)).data.isActive == true);
      allow write: if isAdmin();
    }

    match /activationRedemptions/{id} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow write: if isAdmin();
    }

    match /userUnlockedNpcs/{id} {
      allow get: if signedIn()
        && (!exists(/databases/$(database)/documents/userUnlockedNpcs/$(id))
          || isAdmin()
          || isOwner(resource.data.userId));
      allow list: if isAdmin() || isOwner(resource.data.userId);
      allow create, update, delete: if isAdmin();
    }

    match /activityAttempts/{id} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow write: if isAdmin();
    }

    match /lessonProgress/{id} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow write: if isAdmin();
    }

    match /progress/{id} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow write: if isAdmin();
    }

    match /xpLogs/{id} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow write: if isAdmin();
    }

    match /streaks/{id} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow write: if isAdmin();
    }

    match /badges/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /userBadges/{id} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow write: if isAdmin();
    }

    match /dailyMissions/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /userMissionProgress/{id} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow write: if isAdmin();
    }

    match /subscriptions/{id} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow write: if isAdmin();
    }

    match /voiceUsageLogs/{id} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow write: if isAdmin();
    }

    match /transactions/{id} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow write: if isAdmin();
    }

    match /userMascotCompanions/{id} {
      allow get: if signedIn()
        && (!exists(/databases/$(database)/documents/userMascotCompanions/$(id))
          || isAdmin()
          || isOwner(resource.data.userId));
      allow list: if isAdmin() || isOwner(resource.data.userId);
      allow create, update, delete: if isAdmin();
    }
  }
}
