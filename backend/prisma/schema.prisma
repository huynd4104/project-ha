generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String
  fullName     String
  role         String            @default("PARENT")
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  children     ChildProfile[]
  progress     UserProgress[]
  unlockedNpcs UserUnlockedNpc[]
  xpLogs       XPLog[]
  streaks      Streak[]
}

model ChildProfile {
  id           String            @id @default(cuid())
  userId       String
  name         String
  age          Int
  gender       String?
  note         String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  unlockedNpcs UserUnlockedNpc[]
  progress     UserProgress[]
  xpLogs       XPLog[]
  streaks      Streak[]
}

model NPC {
  id              String            @id @default(cuid())
  name            String
  description     String
  imageUrl        String
  animationUrl    String?
  defaultDialogue String
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  qrCodes         QRCode[]
  lessons         Lesson[]
  unlockedBy      UserUnlockedNpc[]
}

model QRCode {
  id        String            @id @default(cuid())
  code      String            @unique
  npcId     String
  label     String
  isActive  Boolean           @default(true)
  maxUses   Int?
  usedCount Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  npc       NPC               @relation(fields: [npcId], references: [id], onDelete: Cascade)
  unlocks   UserUnlockedNpc[]
}

model UserUnlockedNpc {
  id         String        @id @default(cuid())
  userId     String
  childId    String?
  npcId      String
  qrCodeId   String?
  unlockedAt DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  child      ChildProfile? @relation(fields: [childId], references: [id], onDelete: SetNull)
  npc        NPC           @relation(fields: [npcId], references: [id], onDelete: Cascade)
  qrCode     QRCode?       @relation(fields: [qrCodeId], references: [id], onDelete: SetNull)

  @@unique([userId, npcId])
}

model Lesson {
  id            String         @id @default(cuid())
  title         String
  description   String
  type          String
  orderIndex    Int            @default(0)
  npcId         String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  npc           NPC?           @relation(fields: [npcId], references: [id], onDelete: SetNull)
  mathQuestions MathQuestion[]
  dialogues     Dialogue[]
  flashcards    Flashcard[]
  progress      UserProgress[]
}

model MathQuestion {
  id            String   @id @default(cuid())
  lessonId      String
  questionText  String
  imageUrl      String?
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctOption String
  explanation   String?
  orderIndex    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lesson        Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model Dialogue {
  id            String   @id @default(cuid())
  lessonId      String
  title         String
  sceneText     String
  audioUrl      String?
  questionText  String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctOption String
  orderIndex    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lesson        Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model Flashcard {
  id         String   @id @default(cuid())
  lessonId   String
  frontText  String
  backText   String
  imageUrl   String?
  audioUrl   String?
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lesson     Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model UserProgress {
  id             String        @id @default(cuid())
  userId         String
  childId        String?
  lessonId       String
  status         String        @default("NOT_STARTED")
  score          Int?
  totalQuestions Int?
  correctAnswers Int?
  completedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  child          ChildProfile? @relation(fields: [childId], references: [id], onDelete: SetNull)
  lesson         Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model XPLog {
  id        String        @id @default(cuid())
  userId    String
  childId   String?
  amount    Int
  reason    String
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  child     ChildProfile? @relation(fields: [childId], references: [id], onDelete: SetNull)
}

model Streak {
  id             String        @id @default(cuid())
  userId         String
  childId        String?
  currentStreak  Int           @default(0)
  longestStreak  Int           @default(0)
  lastActiveDate DateTime?
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  child          ChildProfile? @relation(fields: [childId], references: [id], onDelete: SetNull)
}
