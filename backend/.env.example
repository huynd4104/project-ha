PORT=8080
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

DB_URL=jdbc:postgresql://aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require
DB_USERNAME=postgres.your-project-ref
DB_PASSWORD=replace-with-supabase-db-password

JWT_SECRET=replace-with-64-plus-random-characters
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=30

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-test-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=Project HA <your-test-gmail@gmail.com>

R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace-with-r2-access-key
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-key
R2_BUCKET=project-ha-media
R2_PUBLIC_BASE_URL=https://media.example.com
R2_REGION=auto

ENABLE_DEMO_PREMIUM_UPGRADE=true
ENABLE_MOCK_VOICE_PROVIDER=true
VOICE_PROVIDER=mock

GEMINI_API_KEY=
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LIVE_ENABLED=false
GEMINI_LIVE_RESPONSE_LANGUAGE=vi-VN
GEMINI_EVALUATION_ENABLED=true
GEMINI_TEXT_MODEL=gemini-3.5-flash
GEMINI_EVALUATION_TIMEOUT_MS=8000
AI_CONFIG_ENCRYPTION_SECRET=
